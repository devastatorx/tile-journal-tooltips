<div class="tab" data-group="" data-tab="tile-journal-tooltips">
  <div class="form-group">
    <label>Enable Tooltip</label>
    <input type="checkbox" name="flags.tile-journal-tooltips.enabled" {{#if enabled}}checked{{/if}}>
    <p class="notes">
      When enabled, hovering this tile shows a tooltip near the cursor.
      Tooltip content is cached onto the tile when a GM saves, so players can see it without Journal permissions.
    </p>
  </div>

  <div class="form-group">
    <label>Journal Entry (source)</label>
    <select name="flags.tile-journal-tooltips.journalId" class="tjt-journal">
      <option value="">— None —</option>
      {{#each journalOptions}}
        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
      {{/each}}
    </select>
    <p class="notes">Pick the Journal Entry that provides the tooltip text (GM-only read; cached to tile).</p>
  </div>

  <div class="form-group">
    <label>Journal Page (source)</label>
    <select name="flags.tile-journal-tooltips.pageId" class="tjt-page" {{#unless hasJournal}}disabled{{/unless}}>
      <option value="">— First Page / Entry Content —</option>
      {{#each pageOptions}}
        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
      {{/each}}
    </select>
    <p class="notes">
      If unset, the tooltip uses the first page (if pages exist) or the entry content.
      Changing the entry resets this to default.
    </p>
  </div>

  <hr/>

  <div class="form-group">
    <label>Cache status</label>
    <div class="form-fields">
      <span>
        {{#if hasCache}}
          ✅ Cached (last updated: {{cacheUpdated}})
        {{else}}
          ⚠️ Not cached yet (GM must Save this tile)
        {{/if}}
      </span>
    </div>
    <p class="notes">
      Players see only cached content. If you change the Journal text, re-open tile config and Save (or just toggle enable off/on and Save).
    </p>
  </div>
</div>
